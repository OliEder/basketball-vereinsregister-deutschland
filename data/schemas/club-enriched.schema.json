{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vereinsregister.github.io/data/schemas/club-enriched.schema.json",
  "title": "ClubEnriched",
  "type": "object",
  "required": ["clubId"],
  "unevaluatedProperties": false,
  "properties": {
    "clubId": { "type": "integer" },
    "logoUrl": { "type": "string" },
    "website": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "phone": { "type": "string" },
    "address": {
      "type": "object",
      "unevaluatedProperties": false,
      "properties": {
        "street": { "type": "string" },
        "zip": { "type": "string" },
        "city": { "type": "string" }
      }
    },
    "info": { "type": "string" },
    "halls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "dbbSpielfeldId", "bezeichnung"],
        "unevaluatedProperties": false,
        "properties": {
          "id": { "type": ["string", "integer"] },
          "dbbSpielfeldId": { "type": ["integer", "null"] },
          "bezeichnung": { "type": "string" },
          "strasse": { "type": "string" },
          "plz": { "type": "string" },
          "ort": { "type": "string" }
        }
      }
    },
    "teams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["teamPermanentId", "training"],
        "unevaluatedProperties": false,
        "properties": {
          "teamPermanentId": { "type": "integer" },
          "training": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["wochentag", "von", "bis", "hallId"],
              "unevaluatedProperties": false,
              "properties": {
                "wochentag": {
                  "type": "string",
                  "enum": ["Montag", "Dienstag", "Mittwoch", "Donnerstag", "Freitag", "Samstag", "Sonntag"]
                },
                "von": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" },
                "bis": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" },
                "hallId": { "type": ["string", "integer"] }
              }
            }
          }
        }
      }
    }
  }
}
